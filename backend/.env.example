# Backend environment variables
# Copy to .env and fill in values before starting the server.

PORT=3001
FRONTEND_URL=http://localhost:3000

# GitHub credentials
# Leave blank to run in mock mode (returns a fake PR URL – safe for local development)
GITHUB_TOKEN=ghp_your_personal_access_token_here
GITHUB_OWNER=your-github-org-or-username
GITHUB_REPO=your-idp-config-repo
